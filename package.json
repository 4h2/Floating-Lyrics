{
  "name": "floating-lyrics",
  "version": "1.0.0",
  "description": "A premium floating lyrics miniplayer for Spotify on Windows",
  "main": "./out/main/index.js",
  "author": "arthu",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "package": "electron-vite build && electron-builder --win --config electron-builder.yml",
    "package:dir": "electron-vite build && electron-builder --win --dir --config electron-builder.yml"
  },
  "dependencies": {
    "colorthief": "^2.4.0",
    "framer-motion": "^11.18.0",
    "zustand": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.0"
  }
}
