# Floating Lyrics - Environment Variables
# Copy this to .env and fill in your values

# Spotify App Client ID (get from https://developer.spotify.com/dashboard)
MAIN_VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Spotify OAuth Redirect URI (must match your Spotify app settings)
MAIN_VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
